GPL corresponding source: the source corresponding to these binaries is
the upstream code at the tags above. Rebuild recipe (arm64, macOS):

  brew install autoconf automake libtool pkg-config xa coreutils gnu-sed
  # GNU od/sed are required (the 6502 driver rule uses `od -w` and `sed -re`)
  export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:\
/opt/homebrew/opt/gnu-sed/libexec/gnubin:$PATH"
  export LIBTOOLIZE=glibtoolize
  STAGE=/tmp/sidstage

  # 1) libresidfp
  git clone --branch v1.0.2 https://github.com/libsidplayfp/libresidfp
  cd libresidfp && autoreconf -vfi
  ./configure --enable-static --disable-shared --prefix=$STAGE && make && make install

  # 2) libsidplayfp (detects libresidfp via pkg-config -> builds ReSIDfpBuilder)
  git clone --branch v3.0.1 --recurse-submodules https://github.com/libsidplayfp/libsidplayfp
  cd libsidplayfp && autoreconf -vfi
  PKG_CONFIG_PATH=$STAGE/lib/pkgconfig ./configure \
      --enable-static --disable-shared --disable-hardsid --disable-exsid --prefix=$STAGE
  make && make install

  cp $STAGE/lib/libsidplayfp.a $STAGE/lib/libresidfp.a lib/
  cp -R $STAGE/include/sidplayfp/. include/sidplayfp/

If you bump versions, copy the matching headers from the same source into
include/sidplayfp/ so headers and library stay in sync.
